root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{h,hpp,cpp,cxx,inl}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2

[CMakeLists.txt]
indent_style = space
indent_size = 4

[*.cmake]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{glsl,vert,frag,comp,geom}]
indent_style = space
indent_size = 4

[*.lua]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
